{
  "manifest_version": 3,
  "name": "TabView",
  "version": "2.0",
  "description": "Visual tab manager with RAM monitoring, multi-select, tab grouping, and window management.",
  "permissions": ["tabs", "activeTab", "debugger", "processes", "tabGroups"],
  "action": {
    "default_title": "Open TabView"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icon128.png"
  }
}
